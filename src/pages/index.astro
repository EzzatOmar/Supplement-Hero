---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getPublishDate, getPublishedPosts, getScheduledPosts } from '../lib/blog';
import { withBase } from '../lib/urls';

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 3);
const scheduledPosts = await getScheduledPosts();
const nextScheduledPost = scheduledPosts[0];
const queuedPosts = scheduledPosts.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Research-backed supplement explainers for cautious readers.</h1>
			<p>
				Supplement Hero publishes plain-language briefings about supplements, evidence quality, and
				decision-making pitfalls. The site now ships only approved posts whose scheduled publish time
				has passed at build time.
			</p>
			<p>
				The Astro content collection supports an approval gate plus scheduled publishing via
				<code>publishAt</code>. An hourly scheduler can rebuild the site so approved posts land
				without manual intervention.
			</p>
			<p>Published posts today: {posts.length}</p>
			{
				nextScheduledPost && (
					<p>
						Next approved post in queue: <strong>{nextScheduledPost.data.title}</strong> on{' '}
						<FormattedDate date={getPublishDate(nextScheduledPost)} />.
					</p>
				)
			}
			{
				scheduledPosts.length > 0 && (
					<section>
						<h2>Publishing queue</h2>
						<p>
							{scheduledPosts.length} approved {scheduledPosts.length === 1 ? 'post is' : 'posts are'} queued for
							upcoming hourly builds.
						</p>
						<ul>
							{
								queuedPosts.map((post) => (
									<li>
										<a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
										<span> · </span>
										<FormattedDate date={getPublishDate(post)} />
									</li>
								))
							}
						</ul>
					</section>
				)
			}
			<section>
				<h2>Latest posts</h2>
				<ul>
					{
						latestPosts.map((post) => (
							<li>
								<a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
								<span> · </span>
								<FormattedDate date={getPublishDate(post)} />
							</li>
						))
					}
				</ul>
			</section>
			<p>Browse the full <a href={withBase('/blog')}>blog archive</a> or subscribe to the RSS feed.</p>
		</main>
		<Footer />
	</body>
</html>
