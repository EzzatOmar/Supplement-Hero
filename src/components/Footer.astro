---
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} Supplement Hero.</p>
	<p class="note">
		Content is published only after editorial approval and the scheduled publish window has opened.
	</p>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	footer p {
		margin: 0.35rem 0;
	}
	.note {
		max-width: 36rem;
		margin: 0.5rem auto 0;
	}
</style>
